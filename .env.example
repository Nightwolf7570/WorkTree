# Database (use sqlite:./dev.db for local dev, postgresql://... for production)
DATABASE_URL=sqlite:./dev.db

# OpenAI (for embeddings + LLM reasoning)
OPENAI_API_KEY=sk-...

# SerpAPI (for candidate web search enrichment)
SERPAPI_API_KEY=...

# GitHub API (for candidate discovery)
GITHUB_TOKEN=ghp_...

# Stack Auth
STACK_PROJECT_ID=your-project-id
STACK_SECRET_SERVER_KEY=your-secret-server-key

# Server
PORT=3000
NODE_ENV=development
